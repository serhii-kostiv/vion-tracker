{
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["es2023"],
    "target": "ES2023",
    "module": "commonjs",
    "moduleResolution": "node",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictNullChecks": true,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "noFallthroughCasesInSwitch": false,
    "noUncheckedIndexedAccess": false
  }
}
